# Supabase project credentials (required)
# Get these from: Supabase Dashboard → Project Settings → API
#
# Use the anon / public key (JWT starts with eyJ, role "anon").
# NEVER put the service_role key in VITE_* — that causes "Invalid API key" in the browser
# if mismatched, and is a security risk if the service role is exposed.
#
# Local dev: copy this file to .env and fill in values, then run `npm run dev`
# GitHub Pages: add the same keys as repository secrets (Settings → Secrets → Actions):
#   VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY
# After changing secrets, re-run the deploy workflow (Vite bakes env at build time).
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: only if you add custom email integration in the frontend
# VITE_RESEND_API=your-resend-api-key

# Enterprise feature flags (build-time). Default-on flags: unset = enabled; set to false to disable.
# VITE_ENABLE_SMART_REQUEST_HUB=false
# VITE_ENABLE_NOTIFICATIONS=false
# VITE_ENABLE_REQUEST_HUB_REMINDERS=false
# Default-off: must be explicitly true
# VITE_ENABLE_NOTIFICATION_EMAIL=true
# Level 3 (default-off until migrations applied):
# VITE_ENABLE_BEHAVIOUR_ANALYTICS=true
# VITE_ENABLE_FEEDBACK_MODULE=true
# VITE_ENABLE_SUPER_ADMIN_GOVERNANCE=true
# VITE_ENABLE_ENTRY_DUPLICATE_GUARD=true
